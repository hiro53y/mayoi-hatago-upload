{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "skipLibCheck": true,
    "outDir": ".test-build",
    "rootDir": "src",
    "isolatedModules": true
  },
  "include": ["src/game/**/*.ts", "src/tests/**/*.ts"]
}
